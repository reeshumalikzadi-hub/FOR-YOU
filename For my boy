<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>🐻 Bear Love Quiz 🧸</title>
<style>
body{
background:#ffeef5;
font-family:Arial;
text-align:center;
padding:20px;
}
.box{
background:white;
padding:20px;
border-radius:20px;
max-width:500px;
margin:auto;
box-shadow:0 0 15px pink;
}
button{
padding:12px 25px;
margin:10px;
font-size:18px;
border:none;
border-radius:15px;
cursor:pointer;
}
.yes{background:#ff8fb1;color:white;}
.no{background:#b5b5b5;color:white;}
img{
width:180px;
margin-bottom:15px;
}
</style>
</head>

<body>

<div class="box">
<img src="https://i.imgur.com/YQ7X4QF.png">

<h2 id="question">🐻 Kya tum mujhe pasand karte ho?</h2>

<button class="yes" onclick="answer(true)">💖 Yes</button>
<button class="no" onclick="answer(false)">🙈 No</button>

<h3 id="result"></h3>
</div>

<script>
let q=0;
let score=0;

const questions=[
"🐻 Kya tum mujhe pasand karte ho?",
"💖 Kya tum roz mujhse baat karna chahte ho?",
"🥺 Kya tum mujhe miss karte ho?",
"🌸 Kya tum meri smile pasand karte ho?",
"🧸 Kya tum mera khayal rakhoge?",
"💕 Kya tum hamesha mera friend rehna chahte ho?",
"❤️ Sabse important... Kya tum mujhse pyaar karte ho?"
];

function answer(yes){
if(yes) score++;
q++;

if(q<questions.length){
document.getElementById("question").innerHTML=questions[q];
}else{
if(score>=6){
document.getElementById("result").innerHTML="🥹💖 Yay! Lagta hai tum mujhe bohot pasand karte ho! 🧸💕";
}else if(score>=4){
document.getElementById("result").innerHTML="🌸 Hmm... Thoda sa special connection to hai! 🐻";
}else{
document.getElementById("result").innerHTML="🧸 Koi baat nahi! Thanks for playing. 💕";
}
document.getElementById("question").style.display="none";
}
}
</script>

</body>
</html>
